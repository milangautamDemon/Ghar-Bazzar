PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/project

# JWT signing secrets
JWT_KEY_ACCESS_TOKEN=replace-with-access-token-secret
JWT_KEY_REFRESH_TOKEN=replace-with-refresh-token-secret

# Encryption settings
ALGORITHM=aes-256-cbc
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# App URLs
DEVELOPMENT_URI=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
